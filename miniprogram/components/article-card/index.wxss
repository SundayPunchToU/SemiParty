.article-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.article-body {
  flex: 1;
  min-width: 0;
}

.article-title {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: var(--color-text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

.article-source {
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-cover {
  flex-shrink: 0;
  width: 160rpx;
  height: 110rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--color-bg-muted);
}

.article-cover-img {
  width: 100%;
  height: 100%;
}
