.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.tabbar-inner {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  min-height: var(--tabbar-height);
  padding: 10rpx 24rpx calc(env(safe-area-inset-bottom) + 8rpx);
  background: rgba(15, 17, 23, 0.94);
  border-top: 1rpx solid var(--color-border);
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.28);
  backdrop-filter: blur(24rpx);
}

.tabbar-side {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
}

.tabbar-center {
  width: 164rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  margin-top: -38rpx;
}

.tabbar-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  gap: 6rpx;
  padding-bottom: 6rpx;
  color: var(--color-text-tertiary);
}

.tabbar-icon-wrap {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
}

.tabbar-icon {
  width: 40rpx;
  height: 40rpx;
}

.tabbar-text {
  font-size: var(--font-xs);
  color: inherit;
  line-height: 1;
}

.tabbar-item.is-selected {
  color: var(--color-text-primary);
}

.tabbar-item.is-selected .tabbar-icon-wrap {
  background: var(--color-primary-dim);
}

.tabbar-badge {
  position: absolute;
  top: -6rpx;
  right: -14rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: var(--color-danger);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--color-bg-card);
}

.center-trigger {
  width: 104rpx;
  height: 104rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-panel);
}

.center-trigger-core {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow: var(--shadow-fab);
}

.center-trigger-plus {
  color: #fff;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 300;
}

.center-trigger-text {
  margin-top: 8rpx;
  font-size: var(--font-xs);
  color: var(--color-text-primary);
  line-height: 1;
}

.post-panel-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(9, 11, 16, 0.56);
  z-index: 1000;
}

.post-panel-sheet {
  width: 100%;
  padding: 28rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-float);
}

.post-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.post-panel-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.post-panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: var(--color-bg-muted);
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  line-height: 1;
}

.post-panel-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.post-panel-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-height: 176rpx;
  padding: 24rpx;
  border-radius: var(--radius-24);
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-border);
}

.post-panel-card-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: var(--color-primary-dim);
  color: var(--color-text-primary);
  font-size: var(--font-md);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-panel-card-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-primary);
}

.post-panel-card-subtitle {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
}
