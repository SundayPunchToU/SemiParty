.home-shell {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.home-hero {
  margin-bottom: 20rpx;
}

.home-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.home-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.home-tabs {
  display: flex;
  gap: 12rpx;
  margin: 24rpx 0 20rpx;
}

.home-tab {
  min-width: 132rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-tab.is-active {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.home-section {
  min-height: 480rpx;
}

.home-placeholder,
.home-footer {
  padding: 36rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.company-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.company-card {
  padding: 28rpx;
  border-radius: 24rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.company-card-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.company-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.company-meta {
  flex: 1;
  min-width: 0;
}

.company-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.company-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.company-arrow {
  font-size: 40rpx;
  color: var(--color-text-tertiary);
}

.company-info {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.company-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.company-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--color-bg-elevated);
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
