.top-nav {
  position: sticky;
  top: 0;
  z-index: 10;
  margin-bottom: 24rpx;
  background: var(--color-bg-page);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-right {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.profile-card,
.stat-row,
.content-section,
.menu-section {
  margin-bottom: 24rpx;
}

.card-content {
  padding: 40rpx 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 16rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: #fff;
  font-size: 52rpx;
}

.profile-name {
  font-size: var(--font-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.profile-role,
.profile-bio {
  margin-top: 8rpx;
  font-size: var(--font-base);
  color: var(--color-text-secondary);
  text-align: center;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  margin-top: 20rpx;
}

.badge-chip {
  padding: 10rpx 18rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  color: var(--color-text-secondary);
  font-size: var(--font-xs);
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.edit-btn,
.logout-btn {
  width: 100%;
  margin-top: 24rpx;
}

.stat-row {
  display: flex;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: var(--font-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.stat-label {
  margin-top: 6rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.content-section {
  padding: 20rpx 24rpx 12rpx;
}

.content-tabs {
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.content-tab {
  padding: 14rpx 22rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.content-tab.is-active {
  background: var(--color-primary);
  color: #fff;
}

.post-card,
.fav-card,
.history-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.post-card:last-child,
.fav-card:last-child,
.history-card:last-child {
  border-bottom: 0;
}

.post-card-header,
.history-meta {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.post-card-title,
.fav-title,
.history-title {
  font-size: var(--font-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.post-card-time,
.history-time {
  flex-shrink: 0;
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.post-card-meta,
.post-card-stats,
.fav-meta,
.fav-stats,
.history-meta {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.best-badge {
  padding: 4rpx 10rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-dim);
  color: var(--color-primary-text);
}

.history-clear {
  margin-bottom: 8rpx;
  text-align: right;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.menu-section {
  overflow: hidden;
}

.menu-row {
  min-height: 96rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--color-divider);
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-text {
  font-size: var(--font-md);
  color: var(--color-text-primary);
}

.menu-arrow {
  font-size: var(--font-md);
  color: var(--color-text-tertiary);
}

.empty-state {
  padding: 36rpx 0 24rpx;
  text-align: center;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}
