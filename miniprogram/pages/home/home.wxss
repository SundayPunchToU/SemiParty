.top-safe {
  margin-bottom: 12rpx;
}

.page-title {
  font-size: var(--font-xxl);
  margin-bottom: 8rpx;
}

.job-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-left: 3rpx solid var(--color-primary);
}

.job-banner-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-soft);
  color: var(--color-primary-text);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.job-banner-body {
  flex: 1;
  color: var(--color-text-primary);
}

.job-banner-title {
  font-size: var(--font-md);
  font-weight: 700;
}

.job-banner-subtitle {
  margin-top: 4rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.quick-nav-wrap {
  margin-top: 20rpx;
}

.tab-scroll {
  margin: 16rpx 0 16rpx;
  white-space: nowrap;
  border-bottom: 1rpx solid var(--color-divider);
}

.tab-row {
  display: flex;
  gap: 0;
}

.tab-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  border: none;
  border-radius: 0;
  border-bottom: 3rpx solid transparent;
  color: var(--color-text-tertiary);
  font-size: var(--font-base);
  font-weight: 500;
}

.tab-chip.is-active {
  background: none;
  color: var(--color-text-primary);
  font-weight: 700;
  border-bottom-color: var(--color-primary);
}

.news-stream {
  margin-top: 8rpx;
}
