.page-edit {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.top-nav {
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(15, 17, 23, 0.94);
  backdrop-filter: blur(16rpx);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--page-gutter);
  height: 88rpx;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-primary);
}

.nav-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.save-btn {
  min-width: 120rpx;
  height: 60rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-tertiary);
  background: var(--color-bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn.is-active {
  color: #fff;
  background: var(--color-primary);
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 28rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 64rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-panel);
}

.avatar-action {
  margin-top: 16rpx;
  font-size: var(--font-base);
  color: var(--color-primary-text);
}

.form-section {
  padding: 0 var(--page-gutter) 40rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

.form-input,
.form-textarea,
.form-picker {
  width: 100%;
  background: var(--color-bg-input);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-16);
  color: var(--color-text-primary);
  font-size: var(--font-base);
  box-sizing: border-box;
}

.form-input,
.form-picker {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}

.form-textarea {
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  line-height: 1.6;
}
