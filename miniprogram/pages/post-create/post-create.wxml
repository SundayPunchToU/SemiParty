<view class="page-create" style="padding-top: {{statusBarHeight}}px; padding-right: {{navCapsuleInsetRight}}px;">
  <view class="nav-bar" style="height: {{capsuleHeight}}px;">
    <view class="nav-close" bindtap="goBack">✕</view>
    <view class="nav-title">发帖</view>
    <view class="nav-submit {{canPublish ? '' : 'is-disabled'}}" bindtap="handlePublish">
      {{publishing ? '发布中' : '发布'}}
    </view>
  </view>

  <view class="topic-row-wrapper">
    <view class="topic-row-label">选择话题</view>
    <scroll-view class="topic-row" scroll-x="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
      <view class="topic-row-inner">
        <view
          wx:for="{{topics}}"
          wx:key="topicId"
          class="topic-chip {{selectedTopicId === item.topicId ? 'is-active' : ''}}"
          data-id="{{item.topicId}}"
          data-name="{{item.topicName}}"
          bindtap="onTopicTap"
        >{{item.topicName}}</view>
      </view>
    </scroll-view>
  </view>

  <textarea
    class="editor"
    placeholder="聊点什么？技术、八卦、吐槽都行"
    value="{{content}}"
    bindinput="handleContentInput"
    maxlength="5000"
    auto-height="{{true}}"
  />

  <view class="bottom-bar" style="padding-bottom: env(safe-area-inset-bottom);">
    <view class="anon-row">
      <switch color="#3B82F6" checked="{{isAnonymous}}" bindchange="onAnonToggle" />
      <text class="anon-label">匿名发布</text>
    </view>
  </view>
</view>
