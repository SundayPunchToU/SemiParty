<!-- pages/zone-detail/zone-detail.wxml -->
<view class="zone-page">

  <!-- ① 顶部导航栏 -->
  <view class="zone-nav" style="padding-top: {{statusBarHeight}}px; background: rgba(26,26,46,{{navBgOpacity}});">
    <view class="nav-inner" style="height: {{capsuleHeight}}px;">
      <view class="nav-back" bindtap="goBack">
        <text class="nav-back-icon">←</text>
      </view>
      <view class="nav-title" style="opacity: {{showNavTitle ? 1 : 0}};">
        {{zone.zoneName}}
      </view>
      <view class="nav-actions">
        <view class="nav-action-btn" bindtap="onSearchTap">
          <text class="nav-action-icon">🔍</text>
        </view>
        <view class="nav-action-btn" bindtap="onMoreTap">
          <text class="nav-action-icon">⋯</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Loading state -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Error state -->
  <view wx:elif="{{loadError}}" class="error-container">
    <text class="error-text">专区不存在或加载失败</text>
    <view class="error-btn" bindtap="goBack">返回</view>
  </view>

  <!-- Main content -->
  <block wx:else>

    <!-- ② 专区头部信息卡（可折叠） -->
    <view
      class="zone-header"
      style="height: {{headerHeight}}rpx; opacity: {{headerOpacity}}; overflow: hidden;"
    >
      <view class="header-bg">
        <image wx:if="{{zone.zoneBanner}}" class="header-banner" src="{{zone.zoneBanner}}" mode="aspectFill" />
        <view class="header-overlay"></view>
      </view>
      <view class="header-content">
        <view class="zone-avatar">
          <image wx:if="{{zone.zoneIcon}}" class="avatar-img" src="{{zone.zoneIcon}}" mode="aspectFill" />
          <text wx:else class="avatar-text">{{zone.zoneName[0]}}</text>
        </view>
        <view class="zone-meta">
          <view class="zone-name-text">{{zone.zoneName}}</view>
          <view class="zone-desc">{{zone.zoneDesc}}</view>
          <view class="zone-stats">👥 {{zone.memberCount}} 成员 · 📝 今日 {{zone.todayPostCount}} 帖</view>
        </view>
        <view class="zone-actions-row">
          <view
            wx:if="{{zone.isJoined}}"
            class="zone-action-btn zone-btn-joined"
            bindtap="onLeaveZone"
          >已加入 ✓ ▾</view>
          <view
            wx:else
            class="zone-action-btn zone-btn-join"
            bindtap="onJoinZone"
          >+ 加入</view>
          <view class="zone-action-btn zone-btn-share" bindtap="onShareZone">分享</view>
        </view>
      </view>
    </view>

    <!-- ③ Tab 栏（吸顶） -->
    <view class="zone-tabs" style="position: sticky; top: {{statusBarHeight + capsuleHeight}}px; z-index: 10;">
      <scroll-view class="tabs-scroll" scroll-x="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
        <view class="tabs-row">
          <view
            wx:for="{{tabs}}"
            wx:key="tabKey"
            class="tab-item {{activeTab === item.tabKey ? 'is-active' : ''}}"
            data-key="{{item.tabKey}}"
            bindtap="onTabChange"
          >
            <text class="tab-text">{{item.tabName}}</text>
            <view wx:if="{{activeTab === item.tabKey}}" class="tab-indicator"></view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ④ 排序筛选栏 -->
    <view class="sort-bar">
      <picker
        class="sort-picker"
        range="{{sortOptions}}"
        range-key="label"
        value="{{sortIndex}}"
        bindchange="onSortChange"
      >
        <view class="sort-picker-inner">
          <text class="sort-label">{{sortOptions[sortIndex].label}}</text>
          <text class="sort-arrow">▾</text>
        </view>
      </picker>
    </view>

    <!-- ⑤ 置顶帖区 -->
    <view wx:if="{{showPinned && pinnedPosts.length > 0}}" class="pinned-section">
      <view
        wx:for="{{pinnedPosts}}"
        wx:key="postId"
        class="pinned-item"
        data-postid="{{item.postId}}"
        bindtap="onPinnedTap"
      >
        <text class="pinned-icon">📌</text>
        <text class="pinned-tag">{{item.tag}}</text>
        <text class="pinned-title">{{item.title}}</text>
      </view>
    </view>

    <!-- ⑥ 帖子信息流 -->
    <view class="post-list" wx:if="{{!isEmpty}}">
      <view wx:for="{{posts}}" wx:key="id" class="post-item">
        <content-card
          item="{{item}}"
          showZoneName="{{false}}"
          showContentType="{{true}}"
          bind:cardtap="onPostTap"
        />
      </view>
    </view>

    <!-- 空态 -->
    <view wx:if="{{isEmpty && !loading}}" class="empty-state">
      <text class="empty-icon">✏️</text>
      <text class="empty-title">这个专区还很安静</text>
      <text class="empty-text">成为第一个发言的人吧</text>
      <view class="empty-btn" bindtap="onEmptyAction">发布第一条帖子</view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loadingMore}}" class="load-more">
      <text class="load-more-text">加载更多...</text>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && posts.length > 0 && !loadingMore}}" class="no-more">
      <text class="no-more-text">— 没有更多了 —</text>
    </view>

  </block>

  <!-- ⑦ 浮动发帖按钮 -->
  <view class="fab" bindtap="onFabTap">+</view>

</view>
