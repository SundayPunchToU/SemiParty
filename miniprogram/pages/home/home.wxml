<view class="page-shell home-shell">
  <view class="top-safe" style="padding-top: {{statusBarHeight + 8}}px; padding-right: {{navCapsuleInsetRight}}px;">
    <view class="custom-topbar" style="min-height: {{capsuleHeight}}px;">
      <view class="brand">{{brandName}}</view>
    </view>
  </view>

  <view class="home-hero">
    <view class="home-title">首页</view>
    <view class="home-subtitle">资讯、招聘、企业信息统一入口</view>
  </view>

  <search-bar
    placeholder="搜索资讯、帖子、岗位、人才"
    bind:searchtap="onSearchTap"
  />

  <view class="home-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="home-tab {{activeTab === item.key ? 'is-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{loading}}" class="home-placeholder">加载中...</view>

  <view wx:elif="{{activeTab === 'news'}}" class="home-section">
    <view wx:if="{{!newsList.length}}" class="home-placeholder">暂无资讯</view>
    <block wx:for="{{newsList}}" wx:key="id">
      <news-card item="{{item}}" bind:cardtap="openArticle" />
    </block>
    <view class="home-footer">{{pageState.news.hasMore ? (pageState.news.loadingMore ? '加载中...' : '') : '没有更多内容了'}}</view>
  </view>

  <view wx:elif="{{activeTab === 'jobs'}}" class="home-section">
    <view wx:if="{{!jobList.length}}" class="home-placeholder">暂无岗位</view>
    <job-card
      wx:for="{{jobList}}"
      wx:key="id"
      item="{{item}}"
      bind:cardtap="openJobDetail"
      bind:apply="onApplyJob"
    />
    <view class="home-footer">{{pageState.jobs.hasMore ? (pageState.jobs.loadingMore ? '加载中...' : '') : '没有更多内容了'}}</view>
  </view>

  <view wx:else class="home-section company-section">
    <view wx:if="{{!companyList.length}}" class="home-placeholder">暂无企业</view>
    <view
      wx:for="{{companyList}}"
      wx:key="name"
      class="company-card"
      data-company="{{item.name}}"
      bindtap="openCompany"
    >
      <view class="company-card-top">
        <view class="company-logo">{{item.logoText || item.name[0]}}</view>
        <view class="company-meta">
          <view class="company-name">{{item.name}}</view>
          <view class="company-desc">{{item.description}}</view>
        </view>
        <view class="company-arrow">›</view>
      </view>
      <view class="company-info">{{item.industry}} · {{item.city}} · {{item.jobCount}} 个岗位</view>
      <view class="company-tags">
        <text wx:for="{{item.tags}}" wx:key="*this" class="company-tag">{{item}}</text>
      </view>
    </view>
    <view class="home-footer">{{pageState.companies.hasMore ? (pageState.companies.loadingMore ? '加载中...' : '') : '没有更多内容了'}}</view>
  </view>
</view>
