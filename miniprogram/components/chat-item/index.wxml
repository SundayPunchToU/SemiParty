<view class="chat-item" bindtap="handleTap">
  <view class="avatar-{{item.avatarShape}} chat-avatar" style="background: {{item.avatarBg}}; color: {{item.avatarColor}};">
    {{item.avatarText}}
  </view>
  <view class="chat-body">
    <view class="chat-top">
      <!-- === STEP 1.6 修改开始：追加角色标签 === -->
      <view class="chat-name-row">
        <text class="chat-name">{{item.name}}</text>
        <text wx:if="{{item.role}}" class="chat-role-tag">{{item.role}}</text>
      </view>
      <!-- === STEP 1.6 修改结束 === -->
      <text class="chat-time">{{item.time}}</text>
    </view>
    <view class="chat-bottom">
      <text class="chat-message">{{item.lastMessage}}</text>
      <view wx:if="{{item.unread}}" class="chat-badge">{{item.unread}}</view>
    </view>
  </view>
</view>
