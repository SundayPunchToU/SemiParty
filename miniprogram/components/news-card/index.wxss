.news-card {
  padding: 16rpx 0;
}

.news-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.news-title {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: var(--color-text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  flex-wrap: wrap;
}
