.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 28rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary-text);
  font-size: 36rpx;
  border-radius: 20rpx;
}

.profile-name {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.profile-title {
  margin-top: 6rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.status-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--font-sm);
  font-weight: 600;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}
