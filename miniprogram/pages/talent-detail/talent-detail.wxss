.detail-shell {
  padding-bottom: calc(env(safe-area-inset-bottom) + 164rpx);
}

.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn,
.nav-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.back-btn {
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
}

.nav-title {
  font-size: 28rpx;
  font-weight: 600;
}

.hero-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.hero-head {
  display: flex;
  gap: 20rpx;
}

.hero-avatar {
  width: 92rpx;
  height: 92rpx;
  font-size: 34rpx;
}

.hero-main {
  flex: 1;
}

.detail-title {
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 700;
}

.detail-role {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.detail-meta {
  margin-top: 10rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.section-card {
  margin-top: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
}

.section-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
}

.info-label {
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

.info-value {
  font-size: 24rpx;
  text-align: right;
}

.detail-empty {
  padding-top: 120rpx;
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

.bottom-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

.primary-btn {
  height: 88rpx;
  border-radius: 24rpx;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-btn.is-disabled {
  opacity: 0.65;
}
