<view class="tabbar-shell">
  <view class="tabbar-inner">
    <view class="tabbar-side">
      <view
        wx:for="{{list}}"
        wx:key="pagePath"
        wx:if="{{index < 2}}"
        class="tabbar-item {{selected === index ? 'is-selected' : ''}}"
        data-path="{{item.pagePath}}"
        bindtap="switchTab"
      >
        <view class="tabbar-icon-wrap">
          <image
            class="tabbar-icon"
            src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
            mode="aspectFit"
          />
        </view>
        <text class="tabbar-text">{{item.text}}</text>
      </view>
    </view>

    <view class="tabbar-center">
      <view class="center-trigger" bindtap="openPostPanel">
        <view class="center-trigger-core">
          <text class="center-trigger-plus">+</text>
        </view>
      </view>
      <text class="center-trigger-text">发布</text>
    </view>

    <view class="tabbar-side">
      <view
        wx:for="{{list}}"
        wx:key="pagePath"
        wx:if="{{index >= 2}}"
        class="tabbar-item {{selected === index ? 'is-selected' : ''}}"
        data-path="{{item.pagePath}}"
        bindtap="switchTab"
      >
        <view class="tabbar-icon-wrap">
          <image
            class="tabbar-icon"
            src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
            mode="aspectFit"
          />
          <view wx:if="{{item.unreadCount > 0}}" class="tabbar-badge">
            {{item.unreadCount > 99 ? '99+' : item.unreadCount}}
          </view>
        </view>
        <text class="tabbar-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showPostPanel}}" class="post-panel-mask" bindtap="closePostPanel">
    <view class="post-panel-sheet" catchtap="preventBubble">
      <view class="post-panel-header">
        <view class="post-panel-title">选择发布方式</view>
        <view class="post-panel-close" bindtap="closePostPanel">×</view>
      </view>
      <view class="post-panel-grid">
        <view
          wx:for="{{postActions}}"
          wx:key="action"
          class="post-panel-card"
          data-action="{{item.action}}"
          bindtap="handlePostAction"
        >
          <view class="post-panel-card-icon">{{item.icon}}</view>
          <view class="post-panel-card-title">{{item.title}}</view>
          <view class="post-panel-card-subtitle">{{item.subtitle}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
