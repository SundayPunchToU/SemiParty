<cover-view class="tab-bar">
  <cover-view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <cover-view class="tab-icon-wrap">
      <cover-image class="tab-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}" />
      <cover-view wx:if="{{item.badge !== '' && item.badge > 0}}" class="badge">
        <cover-view class="badge-text">{{item.badge > 99 ? '99+' : item.badge}}</cover-view>
      </cover-view>
      <cover-view wx:if="{{item.dot}}" class="dot"></cover-view>
    </cover-view>
    <cover-view class="tab-text {{selected === index ? 'tab-text-active' : ''}}">{{item.text}}</cover-view>
  </cover-view>
</cover-view>
