.page-edit {
  min-height: 100vh;
  background: #1A1A2E;
}
.top-nav {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #1A1A2E;
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  height: 88rpx;
}
.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}
.save-btn {
  padding: 10rpx 32rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  background: #333;
}
.save-btn.is-active {
  color: #fff;
  background: #2A7FFF;
}

/* 头像区 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 24rpx;
}
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2A7FFF, #5B9CFF);
  color: #fff;
  font-size: 64rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-action {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #2A7FFF;
}

/* 表单 */
.form-section {
  padding: 0 32rpx;
}
.form-item {
  margin-bottom: 32rpx;
}
.form-label {
  font-size: 28rpx;
  color: #aaa;
  margin-bottom: 12rpx;
  display: block;
}
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #2A2A3E;
  border-radius: 16rpx;
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #2A2A3E;
  border-radius: 16rpx;
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}
.form-picker {
  height: 88rpx;
  padding: 0 24rpx;
  background: #2A2A3E;
  border-radius: 16rpx;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}
