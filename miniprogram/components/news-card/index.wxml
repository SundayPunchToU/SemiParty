<view class="news-card" bindtap="handleTap">
  <view class="news-tags">
    <text wx:for="{{item.tags}}" wx:key="text" class="tag tag-{{item.type}}">{{item.text}}</text>
  </view>
  <view class="news-title">{{item.title}}</view>
  <view class="news-meta">
    <text>{{item.source}}</text>
    <text>{{relativeTime}}</text>
    <text>{{viewCount}} 阅读</text>
  </view>
</view>
