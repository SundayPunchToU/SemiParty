.chat-shell {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--color-bg-page);
}

.chat-nav {
  display: grid;
  grid-template-columns: 64rpx 1fr 64rpx;
  align-items: center;
  gap: 12rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-bg-muted);
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.chat-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.chat-nav-placeholder {
  width: 64rpx;
  height: 64rpx;
}

.message-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
  padding-bottom: 128rpx;
}

.chat-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.message-row {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 16rpx;
}

.message-row.is-mine {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 520rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx 20rpx 20rpx 8rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.message-bubble.is-mine {
  border-radius: 20rpx 20rpx 8rpx 20rpx;
  background: var(--color-primary-dim);
  border-color: rgba(59, 130, 246, 0.22);
}

.message-text {
  font-size: var(--font-base);
  line-height: 1.6;
  color: var(--color-text-primary);
}

.message-time {
  margin-top: 6rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.composer-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 16rpx);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 22rpx;
  background: rgba(24, 28, 36, 0.96);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-panel);
}

.composer-input {
  flex: 1;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: var(--color-bg-input);
  color: var(--color-text-primary);
  font-size: var(--font-sm);
}

.composer-send {
  width: 112rpx;
  height: 68rpx;
  border-radius: 16rpx;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-sm);
  font-weight: 700;
}

.composer-send.is-disabled {
  opacity: 0.6;
}
