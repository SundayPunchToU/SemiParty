.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 24rpx;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  background: #dce8ff;
  color: #165dc6;
  font-size: 36rpx;
}

.profile-name {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-title {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.status-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}
