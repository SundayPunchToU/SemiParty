.message-tabs {
  display: flex;
  gap: 0;
  margin: 16rpx 0 20rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.message-tab {
  position: relative;
  padding: 14rpx 24rpx 18rpx;
  border-radius: 0;
  border: 0;
  border-bottom: 3rpx solid transparent;
  color: var(--color-text-tertiary);
  font-size: var(--font-base);
  font-weight: 500;
}

.message-tab + .message-tab {
  margin-left: 0;
}

.message-tab.is-active {
  background: none;
  color: var(--color-text-primary);
  font-weight: 700;
  border-bottom-color: var(--color-primary);
}

.interaction-stream,
.msg-list {
  padding: 0 4rpx 16rpx;
}

.interaction-item,
.msg-item,
.notif-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.interaction-item,
.notif-item {
  align-items: flex-start;
}

.msg-item {
  align-items: center;
}

.interaction-avatar,
.msg-avatar-circle,
.msg-avatar-rounded,
.notif-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
}

.interaction-avatar,
.msg-avatar-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.interaction-avatar {
  background: var(--color-bg-muted);
  font-size: 28rpx;
}

.interaction-body,
.msg-body,
.notif-body {
  flex: 1;
  min-width: 0;
}

.interaction-top {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 6rpx;
}

.interaction-nickname,
.msg-name,
.notif-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.interaction-nickname {
  flex-shrink: 0;
}

.interaction-action {
  font-size: 28rpx;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.interaction-target,
.msg-text,
.msg-member-count,
.notif-content {
  color: var(--color-text-secondary);
}

.interaction-target {
  margin-bottom: 6rpx;
  font-size: var(--font-base);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.interaction-time,
.msg-time,
.notif-time {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.msg-top,
.msg-bottom,
.notif-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.msg-bottom {
  margin-top: 8rpx;
}

.msg-name-row,
.notif-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.msg-text {
  flex: 1;
  min-width: 0;
  font-size: var(--font-sm);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.msg-role-tag {
  flex-shrink: 0;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  color: var(--color-text-secondary);
  font-size: 20rpx;
}

.msg-badge {
  flex-shrink: 0;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  background: var(--color-danger);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.msg-avatar-circle {
  background: var(--color-primary);
  font-size: 28rpx;
}

.msg-avatar-rounded {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  background: var(--color-success-soft);
  font-size: 24rpx;
}

.msg-member-count {
  flex-shrink: 0;
  font-size: var(--font-xs);
}

.notif-item.is-read {
  opacity: 0.66;
}

.notif-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  font-size: 28rpx;
}

.notif-body {
  flex: 1;
  min-width: 0;
}

.notif-top {
  margin-bottom: 6rpx;
}

.notif-unread-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
}

.notif-content {
  font-size: var(--font-sm);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
/* === STEP 1.6 增强 修改结束 === */

/* === STEP 1.6 增强 II 修改开始：左滑操作样式 === */
.swipe-wrapper {
  position: relative;
  overflow: hidden;
  margin-bottom: 16rpx;
  border-radius: var(--radius-lg);
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  z-index: 1;
}

.swipe-actions-2 {
  width: 256rpx;
}

.swipe-actions-3 {
  width: 384rpx;
}

.swipe-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  color: #fff;
  flex-shrink: 0;
}

.swipe-btn-read {
  width: 128rpx;
  background: var(--color-bg-muted);
}

.swipe-btn-pin {
  width: 128rpx;
  background: var(--color-warning);
}

.swipe-btn-delete {
  width: 128rpx;
  background: var(--color-danger);
}

.swipe-content {
  position: relative;
  z-index: 2;
  background: transparent;
  transition: transform 0.2s ease;
}

.is-pinned {
  background: var(--color-bg-elevated);
}

.interaction-stream .swipe-wrapper {
  position: relative;
  overflow: hidden;
}

.is-pinned::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: var(--color-primary);
  border-radius: 0 3rpx 3rpx 0;
}
/* === STEP 1.6 增强 II 修改结束 === */
