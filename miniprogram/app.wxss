page {
  --color-primary: #2a7fff;
  --color-primary-soft: #dce8ff;
  --color-primary-strong: #165dc6;
  --color-success: #1da57a;
  --color-success-soft: #ddf5ee;
  --color-warning: #c88d33;
  --color-warning-soft: #fdf0d8;
  --color-purple: #6f6bf5;
  --color-purple-soft: #ecebff;
  --color-mint: #57ad96;
  --color-mint-soft: #dbf4ee;
  --color-coral: #d07d52;
  --color-coral-soft: #fbe9df;
  --color-bg-page: #262522;
  --color-bg-elevated: #2c2b28;
  --color-bg-muted: #353430;
  --color-bg-input: #312f2c;
  --color-text-primary: #f7f4ef;
  --color-text-secondary: #c4beb4;
  --color-text-tertiary: #8c867b;
  --color-text-dim: #6f6a61;
  --color-border: #45423d;
  --color-divider: rgba(255, 255, 255, 0.08);
  --font-xs: 20rpx;
  --font-sm: 22rpx;
  --font-base: 24rpx;
  --font-md: 26rpx;
  --font-lg: 30rpx;
  --font-xl: 34rpx;
  --font-xxl: 40rpx;
  --radius-sm: 6rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 36rpx;
  --radius-full: 999rpx;
  --shadow-card: 0 20rpx 50rpx rgba(0, 0, 0, 0.18);
  background: var(--color-bg-page);
  color: var(--color-text-primary);
  font-size: var(--font-md);
  line-height: 1.5;
}

view,
text,
scroll-view,
swiper,
swiper-item,
input,
textarea,
button,
image,
rich-text {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 0 24rpx calc(env(safe-area-inset-bottom) + 118rpx);
  background: radial-gradient(circle at top right, rgba(42, 127, 255, 0.12), transparent 32%),
    radial-gradient(circle at top left, rgba(113, 220, 189, 0.08), transparent 28%),
    var(--color-bg-page);
}

.inner-shell {
  min-height: 100vh;
  padding: 0 24rpx calc(env(safe-area-inset-bottom) + 128rpx);
  background: var(--color-bg-page);
}

.custom-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.brand {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.top-pill {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  background: rgba(42, 127, 255, 0.22);
  color: #8dc0ff;
  font-size: 22rpx;
}

.page-title {
  font-size: var(--font-xxl);
  line-height: 1.1;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 14rpx 0 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
}

.section-link {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.panel {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.soft-panel {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-lg);
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.5;
}

.tag-blue {
  background: var(--color-primary-soft);
  color: var(--color-primary-strong);
}

.tag-green {
  background: var(--color-success-soft);
  color: #117154;
}

.tag-orange {
  background: var(--color-warning-soft);
  color: #9a620f;
}

.tag-purple {
  background: var(--color-purple-soft);
  color: #5851d8;
}

.tag-mint {
  background: var(--color-mint-soft);
  color: #257e66;
}

.tag-coral {
  background: var(--color-coral-soft);
  color: #a95b36;
}

.divider {
  height: 1rpx;
  background: var(--color-divider);
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-card {
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: var(--color-bg-elevated);
  text-align: center;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-label {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.menu-group {
  margin-top: 16rpx;
}

.menu-title {
  margin-bottom: 8rpx;
  padding-left: 4rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.menu-list {
  overflow: hidden;
  border-radius: 16rpx;
  background: var(--color-bg-elevated);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 18rpx 16rpx;
  gap: 16rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid var(--color-divider);
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.menu-content {
  flex: 1;
}

.menu-name {
  font-size: 26rpx;
  font-weight: 600;
}

.menu-desc {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.avatar-circle,
.avatar-rounded {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 700;
}

.avatar-circle {
  border-radius: 50%;
}

.avatar-rounded {
  border-radius: 16rpx;
}

.empty-note,
.list-footer {
  padding: 18rpx 0 0;
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: 22rpx;
}
