.job-card {
  padding: var(--card-pad);
  margin-bottom: 18rpx;
}

.job-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.job-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.job-meta {
  margin-top: 6rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.job-salary {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.job-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.job-tag {
  padding: 8rpx 14rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  color: var(--color-text-secondary);
  font-size: var(--font-xs);
}

.job-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.job-bonus {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.job-apply {
  min-width: 152rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-dim);
  color: var(--color-primary-text);
  font-size: var(--font-sm);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.job-apply.is-loading {
  opacity: 0.6;
}
