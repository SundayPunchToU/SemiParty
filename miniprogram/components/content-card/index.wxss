/* === STEP 1.4 新增：ContentCard 样式 === */

/* 卡片整体 */
.content-card {
  background: #1E1E32;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

/* A区：来源标签行 */
.card-tag-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.zone-name {
  font-size: 24rpx;
  color: #4FC3F7;
}

.tag-sep {
  font-size: 24rpx;
  color: #666666;
  margin: 0 10rpx;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* B区：作者信息行 */
.card-author-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.author-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.author-name {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 700;
  margin-left: 12rpx;
}

.author-role {
  font-size: 24rpx;
  color: #999999;
  margin-left: 4rpx;
}

.author-time {
  font-size: 24rpx;
  color: #666666;
  margin-left: 4rpx;
}

/* C区：内容主体 */
.card-body {
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  color: #EEEEEE;
  font-weight: 700;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.5;
}

.card-summary {
  font-size: 28rpx;
  color: #AAAAAA;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.5;
}

.card-topic-tag {
  font-size: 26rpx;
  color: #8D6E63;
  margin-top: 8rpx;
}

/* D区：互动数据行 */
.card-action-row {
  display: flex;
  align-items: center;
  gap: 48rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 28rpx;
}

.action-num {
  font-size: 24rpx;
  color: #666666;
}
