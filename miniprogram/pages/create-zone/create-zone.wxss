.page-shell {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.top-safe {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(15, 17, 23, 0.94);
  backdrop-filter: blur(16rpx);
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 var(--page-gutter);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-text-primary);
  font-weight: 700;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.nav-submit {
  min-width: 116rpx;
  height: 60rpx;
  padding: 0 28rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-base);
  font-weight: 700;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-submit.disabled {
  background: var(--color-bg-muted);
  color: var(--color-text-tertiary);
}

.form-area {
  padding: 180rpx var(--page-gutter) 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

.required {
  color: var(--color-danger);
}

.form-input,
.form-textarea {
  width: 100%;
  background: var(--color-bg-input);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-16);
  padding: 24rpx;
  font-size: var(--font-base);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  border: 1rpx solid transparent;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  font-weight: 600;
}

.chip.is-active {
  background: var(--color-primary-dim);
  border-color: rgba(59, 130, 246, 0.24);
  color: var(--color-primary-text);
}

.icon-upload {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-16);
  background: var(--color-bg-input);
  border: 1rpx dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-upload-plus {
  font-size: 48rpx;
  color: var(--color-text-tertiary);
}

.form-hint {
  padding: 32rpx 0 16rpx;
  text-align: center;
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
}

.success-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.success-modal {
  width: 560rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-24);
  padding: 56rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-float);
}

.success-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.success-title {
  margin-bottom: 12rpx;
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.success-desc {
  margin-bottom: 40rpx;
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

.success-btn {
  width: 100%;
  padding: 22rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-base);
  font-weight: 700;
  text-align: center;
  border-radius: var(--radius-16);
}
