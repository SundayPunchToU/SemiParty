page {
  --color-bg-page: #0f1117;
  --color-bg-card: #181c24;
  --color-bg-elevated: #1e2330;
  --color-bg-muted: #252a36;
  --color-bg-input: #1a1f2b;
  --color-text-primary: #eef0f5;
  --color-text-secondary: #8b92a8;
  --color-text-tertiary: #555e75;
  --color-text-dim: #3a4155;
  --color-border: rgba(255, 255, 255, 0.07);
  --color-divider: rgba(255, 255, 255, 0.05);
  --color-primary: #3b82f6;
  --color-primary-dim: rgba(59, 130, 246, 0.12);
  --color-primary-soft: #1e3a5f;
  --color-primary-text: #93c5fd;
  --color-success: #10b981;
  --color-success-dim: rgba(16, 185, 129, 0.12);
  --color-success-soft: #0d3d2e;
  --color-success-text: #6ee7b7;
  --color-warning: #f59e0b;
  --color-warning-dim: rgba(245, 158, 11, 0.12);
  --color-warning-soft: #3d2e0a;
  --color-warning-text: #fcd34d;
  --color-purple: #8b5cf6;
  --color-purple-soft: rgba(139, 92, 246, 0.16);
  --color-mint: #14b8a6;
  --color-mint-soft: rgba(20, 184, 166, 0.16);
  --color-coral: #fb7185;
  --color-coral-soft: rgba(251, 113, 133, 0.16);
  --color-like-active: #f87171;
  --color-danger: #ef4444;
  --color-danger-soft: rgba(239, 68, 68, 0.14);
  --color-danger-text: #fca5a5;
  --color-info-soft: rgba(59, 130, 246, 0.1);
  --font-xs: 20rpx;
  --font-sm: 22rpx;
  --font-base: 26rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 38rpx;
  --font-xxl: 48rpx;
  --space-12: 12rpx;
  --space-16: 16rpx;
  --space-24: 24rpx;
  --space-32: 32rpx;
  --radius-xs: 6rpx;
  --radius-sm: 10rpx;
  --radius-md: 14rpx;
  --radius-lg: 18rpx;
  --radius-xl: 24rpx;
  --radius-12: 12rpx;
  --radius-16: 16rpx;
  --radius-24: 24rpx;
  --radius-full: 999rpx;
  --page-gutter: 32rpx;
  --card-pad: 24rpx;
  --section-gap: 32rpx;
  --shadow-card: 0 1rpx 0 var(--color-border);
  --shadow-fab: 0 8rpx 24rpx rgba(0, 0, 0, 0.4), 0 2rpx 8rpx rgba(59, 130, 246, 0.3);
  --shadow-float: 0 16rpx 40rpx rgba(0, 0, 0, 0.5);
  --shadow-panel: 0 12rpx 36rpx rgba(0, 0, 0, 0.28);
  --tabbar-height: 118rpx;
  --tabbar-safe-height: calc(env(safe-area-inset-bottom) + 118rpx);
  background: var(--color-bg-page);
  color: var(--color-text-primary);
  font-size: var(--font-base);
  line-height: 1.55;
}

view,
text,
scroll-view,
swiper,
swiper-item,
input,
textarea,
button,
image,
rich-text {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 0 var(--page-gutter) var(--tabbar-safe-height);
  background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.12), transparent 32%),
    radial-gradient(circle at top left, rgba(16, 185, 129, 0.06), transparent 26%),
    var(--color-bg-page);
}

.inner-shell {
  min-height: 100vh;
  padding: 0 var(--page-gutter) calc(env(safe-area-inset-bottom) + 128rpx);
  background: var(--color-bg-page);
}

.page-feed,
.page-form,
.page-profile-shell,
.page-detail-shell {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.page-feed,
.page-profile-shell,
.page-detail-shell {
  padding: 0 var(--page-gutter) var(--tabbar-safe-height);
}

.page-form {
  padding: 0 var(--page-gutter) calc(env(safe-area-inset-bottom) + 144rpx);
}

.custom-topbar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.brand {
  text-align: center;
  font-size: 30rpx;
  color: rgba(238, 240, 245, 0.92);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.topbar-spacer {
  justify-self: start;
  width: 152rpx;
  height: 1rpx;
}

.topbar-action {
  justify-self: end;
  width: 152rpx;
}

.top-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  background: rgba(42, 127, 255, 0.22);
  color: #8dc0ff;
  font-size: 22rpx;
}

.page-title {
  font-size: var(--font-xxl);
  line-height: 1.08;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 0 16rpx;
}

.section-title {
  font-size: var(--font-md);
  font-weight: 700;
}

.section-link {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.panel {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.soft-panel {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
}

.card-base {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-24);
  box-shadow: var(--shadow-card);
}

.card-soft {
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-16);
}

.section-block {
  margin-top: var(--space-24);
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-16);
  margin-bottom: var(--space-16);
}

.section-title-main {
  font-size: var(--font-lg);
  line-height: 1.25;
  font-weight: 700;
}

.section-title-sub {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 600;
  line-height: 1.4;
}

.tag-blue {
  background: var(--color-primary-soft);
  color: var(--color-primary-text);
}

.tag-green {
  background: var(--color-success-soft);
  color: var(--color-success-text);
}

.tag-orange {
  background: var(--color-warning-soft);
  color: var(--color-warning-text);
}

.tag-purple {
  background: var(--color-purple-soft);
  color: #c4b5fd;
}

.tag-mint {
  background: var(--color-mint-soft);
  color: #7ceadf;
}

.tag-coral {
  background: var(--color-coral-soft);
  color: #fda4af;
}

.tag-danger {
  background: var(--color-danger-soft);
  color: var(--color-danger-text);
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  font-weight: 600;
  border: 1rpx solid transparent;
}

.chip-active {
  background: var(--color-primary-dim);
  color: var(--color-text-primary);
  border-color: rgba(59, 130, 246, 0.22);
}

.divider {
  height: 1rpx;
  background: var(--color-divider);
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-card {
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  text-align: center;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-label {
  margin-top: 4rpx;
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.menu-group {
  margin-top: 24rpx;
}

.menu-title {
  margin-bottom: 10rpx;
  padding-left: 4rpx;
  font-size: var(--font-sm);
  color: var(--color-text-dim);
}

.menu-list {
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 18rpx;
  gap: 16rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid var(--color-divider);
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.menu-content {
  flex: 1;
}

.menu-name {
  font-size: var(--font-base);
  font-weight: 600;
}

.menu-desc {
  margin-top: 4rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--color-text-dim);
}

.avatar-circle,
.avatar-rounded {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 700;
}

.avatar-circle {
  border-radius: 50%;
}

.avatar-rounded {
  border-radius: 16rpx;
}

.empty-note,
.list-footer {
  padding: 24rpx 0 0;
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: var(--font-sm);
}

.status-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
  text-align: center;
}

.status-title {
  font-size: var(--font-md);
  line-height: 1.3;
  font-weight: 700;
}

.status-desc {
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.status-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-12);
  margin-top: var(--space-24);
}

.btn-primary,
.btn-secondary,
.btn-danger {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 152rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: 700;
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
}

.btn-secondary {
  background: var(--color-bg-muted);
  color: var(--color-text-primary);
}

.btn-danger {
  background: var(--color-danger-soft);
  color: var(--color-danger-text);
}

.btn-disabled {
  opacity: 0.45;
}
