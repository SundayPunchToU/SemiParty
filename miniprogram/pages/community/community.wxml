<view class="page-shell community-shell">
  <!-- === STEP 1.5 修改开始：模块 A 顶部栏 === -->
  <view class="top-safe" style="padding-top: {{statusBarHeight + 8}}px; padding-right: {{navCapsuleInsetRight}}px;">
    <view class="community-topbar" style="min-height: {{capsuleHeight}}px;">
      <view class="community-title">社区</view>
      <view class="search-icon" bindtap="onSearchTap">
        <text class="search-icon-text">🔍</text>
      </view>
    </view>
  </view>
  <!-- === STEP 1.5 修改结束 === -->

  <!-- === STEP 1.5 修改开始：模块 B 晶圆茶水间入口卡片 === -->
  <view class="tea-room-card" bindtap="goToTeaRoom">
    <view class="tea-room-left">
      <view class="tea-room-name">☕ 晶圆茶水间</view>
      <view class="tea-room-desc">半导体人的深夜食堂</view>
      <view class="tea-room-stats">🟢 {{teaRoomOnlineCount}} 人在线 · 今日 {{teaRoomTodayPosts}} 帖</view>
    </view>
    <view class="tea-room-arrow">›</view>
  </view>
  <!-- === STEP 1.5 修改结束 === -->

  <!-- === STEP 1.5 修改开始：模块 C 我的专区（横向滑动） === -->
  <view class="my-zones-section">
    <view class="section-header">
      <view class="section-title">我的专区</view>
      <view class="section-more" bindtap="onViewAllZones">全部 ></view>
    </view>
    <block wx:if="{{hasMyZones}}">
      <scroll-view class="my-zones-scroll" scroll-x="true" enable-flex="true" show-scrollbar="{{false}}">
        <view class="my-zones-row">
          <view
            wx:for="{{myZones}}"
            wx:key="zoneId"
            class="my-zone-card"
            data-zoneid="{{item.zoneId}}"
            bindtap="onZoneTap"
          >
            <view class="my-zone-name">{{item.zoneName}}</view>
            <view wx:if="{{item.hasNew}}" class="my-zone-dot"></view>
          </view>
        </view>
      </scroll-view>
    </block>
    <block wx:else>
      <view class="my-zones-empty">
        <view class="empty-text">加入专区，找到你的圈子</view>
        <view class="empty-action" bindtap="onGoDiscover">去看看 →</view>
      </view>
    </block>
  </view>
  <!-- === STEP 1.5 修改结束 === -->

  <!-- === STEP 1.5 修改开始：模块 D 专区分类导航 === -->
  <view class="zone-section">
    <scroll-view class="category-chips-scroll" scroll-x="true" enable-flex="true" show-scrollbar="{{false}}">
      <view class="category-chips-row">
        <view
          wx:for="{{zoneCategories}}"
          wx:key="key"
          class="zone-category-chip {{activeCategory === item.key ? 'is-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onCategoryTap"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{zoneListLoading}}" class="zone-list-loading">加载中...</view>
    <view wx:elif="{{currentZoneList.length === 0}}" class="zone-list-loading">暂无专区</view>
    <view wx:else class="zone-list">
      <view
        wx:for="{{currentZoneList}}"
        wx:key="zoneId"
        class="zone-item"
        data-zoneid="{{item.zoneId}}"
        bindtap="onZoneTap"
      >
        <view class="zone-icon">{{item.zoneName[0]}}</view>
        <view class="zone-info">
          <view class="zone-name">{{item.zoneName}}</view>
          <view class="zone-meta">{{item.memberCount}} 成员 · 今日 {{item.todayPosts}} 帖</view>
        </view>
        <view
          wx:if="{{item.isJoined}}"
          class="zone-btn zone-btn-joined"
          data-zoneid="{{item.zoneId}}"
          catchtap="onJoinToggle"
        >已加入 ✓</view>
        <view
          wx:else
          class="zone-btn zone-btn-join"
          data-zoneid="{{item.zoneId}}"
          catchtap="onJoinToggle"
        >+ 加入</view>
      </view>
    </view>
  </view>
  <!-- === STEP 1.5 修改结束 === -->

  <!-- === Step 2.5 增强：创建专区入口 === -->
  <view class="create-zone-entry">
    <view class="create-zone-title">没找到你的圈子？</view>
    <view class="create-zone-card" bindtap="onCreateZone">
      <view class="create-zone-card-title">＋ 申请创建专区</view>
      <view class="create-zone-card-desc">满足条件即可创建属于你的行业交流圈子</view>
    </view>
  </view>
  <!-- === Step 2.5 增强结束 === -->

  <!-- 浮动发帖按钮已移至底部导航栏中央 -->
</view>
