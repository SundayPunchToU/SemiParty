.quick-nav-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0;
}

.quick-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 4rpx;
}

.quick-nav-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.quick-nav-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}
