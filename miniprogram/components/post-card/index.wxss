.post-card {
  padding: 16rpx 0;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.post-avatar {
  width: 60rpx;
  height: 60rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.post-author {
  flex: 1;
  min-width: 0;
}

.post-name {
  font-size: 26rpx;
  font-weight: 700;
}

.post-role {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.post-content {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--color-text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.post-action.is-active {
  color: var(--color-primary);
}

.post-time {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}
