.page-follow {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.top-nav {
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(15, 17, 23, 0.94);
  backdrop-filter: blur(16rpx);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--page-gutter);
  height: 88rpx;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-primary);
}

.nav-tabs {
  display: flex;
  gap: 48rpx;
}

.nav-tab {
  position: relative;
  padding-bottom: 10rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
}

.nav-tab.is-active {
  color: var(--color-text-primary);
}

.nav-tab.is-active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
}

.list-wrap {
  padding: 12rpx var(--page-gutter) 32rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 16rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.row-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.row-info {
  flex: 1;
  min-width: 0;
}

.row-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.row-detail {
  margin-top: 6rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.follow-btn {
  min-width: 120rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  color: var(--color-primary-text);
  background: var(--color-primary-dim);
  font-size: var(--font-sm);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.follow-btn.is-followed {
  border-color: var(--color-border);
  color: var(--color-text-secondary);
  background: var(--color-bg-muted);
}

.follow-btn.is-mutual {
  border-color: transparent;
  color: #fff;
  background: var(--color-primary);
}
