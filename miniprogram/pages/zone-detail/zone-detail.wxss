/* pages/zone-detail/zone-detail.wxss */

.zone-page {
  min-height: 100vh;
  background: #1A1A2E;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ── ① 顶部导航栏 ── */
.zone-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  transition: background 0.15s ease;
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 700;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
  transition: opacity 0.2s ease;
  pointer-events: none;
}

.nav-actions {
  display: flex;
  align-items: center;
  margin-left: auto;
  z-index: 2;
}

.nav-action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-action-icon {
  font-size: 32rpx;
}

/* ── Loading / Error ── */
.loading-container,
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 400rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #888888;
}

.error-text {
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 24rpx;
}

.error-btn {
  padding: 16rpx 48rpx;
  background: #2A7FFF;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 32rpx;
}

/* ── ② 专区头部信息卡 ── */
.zone-header {
  position: relative;
  width: 100%;
  transition: height 0.05s linear, opacity 0.15s ease;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.header-banner {
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(26,26,46,0.3) 0%, rgba(26,26,46,0.85) 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
  box-sizing: border-box;
}

.zone-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2A7FFF, #4FC3F7);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.zone-meta {
  margin-bottom: 16rpx;
}

.zone-name-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.zone-desc {
  font-size: 28rpx;
  color: #AAAAAA;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.zone-stats {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 20rpx;
}

.zone-actions-row {
  display: flex;
  gap: 16rpx;
}

.zone-action-btn {
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.zone-btn-joined {
  background: #333333;
  color: #999999;
}

.zone-btn-join {
  background: #2A7FFF;
  color: #ffffff;
}

.zone-btn-share {
  background: transparent;
  color: #AAAAAA;
  border: 2rpx solid #555555;
}

/* ── ③ Tab 栏 ── */
.zone-tabs {
  background: #1A1A2E;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-row {
  display: flex;
  padding: 0 16rpx;
}

.tab-item {
  position: relative;
  flex-shrink: 0;
  padding: 20rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-text {
  font-size: 28rpx;
  color: #888888;
  transition: color 0.2s ease;
}

.tab-item.is-active .tab-text {
  color: #ffffff;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #4FC3F7;
}

/* ── ④ 排序筛选栏 ── */
.sort-bar {
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  background: #1A1A2E;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.sort-picker {
  height: 100%;
  display: flex;
  align-items: center;
}

.sort-picker-inner {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sort-label {
  font-size: 26rpx;
  color: #AAAAAA;
}

.sort-arrow {
  font-size: 22rpx;
  color: #888888;
}

/* ── ⑤ 置顶帖区 ── */
.pinned-section {
  background: #2A2A3E;
  padding: 16rpx 32rpx;
  margin-bottom: 16rpx;
}

.pinned-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.pinned-item:last-child {
  border-bottom: none;
}

.pinned-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.pinned-tag {
  font-size: 22rpx;
  color: #888888;
  margin-right: 12rpx;
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 6rpx;
}

.pinned-title {
  font-size: 28rpx;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* ── ⑥ 帖子信息流 ── */
.post-list {
  padding: 0 24rpx;
}

.post-item {
  margin-bottom: 0;
}

/* ── 空态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: #2A7FFF;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 32rpx;
}

/* ── 加载更多 / 没有更多 ── */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: #888888;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.no-more-text {
  font-size: 24rpx;
  color: #555555;
}

/* ── ⑦ 浮动发帖按钮 ── */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #4FC3F7;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 24rpx rgba(79, 195, 247, 0.4);
  z-index: 200;
}
