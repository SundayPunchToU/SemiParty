<view class="page-profile page-profile-shell">
  <view class="top-nav" style="padding-top: {{statusBarHeight + 8}}px; padding-right: {{navCapsuleInsetRight}}px;">
    <view class="nav-inner" style="min-height: {{capsuleHeight}}px;">
      <view class="brand">SemiParty</view>
      <view class="nav-right" bindtap="goSettings">⚙</view>
    </view>
  </view>

  <view class="profile-card card">
    <view class="card-content">
      <view class="avatar profile-avatar">{{profile.avatarText || (profile.nickname ? profile.nickname.slice(0, 1) : "U")}}</view>
      <view class="profile-name">{{profile.nickname}}</view>
      <view class="profile-role">{{profile.role}} · {{profile.company}} · {{profile.experience}}</view>
      <view class="profile-bio">{{profile.bio || "完善资料后，让同行更快认识你"}}</view>
      <view class="badge-row">
        <view wx:for="{{profile.badges}}" wx:key="id" class="badge-chip">
          <text>{{item.icon}}</text>
          <text>{{item.name}}</text>
        </view>
      </view>
      <view class="edit-btn btn btn-secondary-muted" bindtap="goEditProfile">编辑资料</view>
    </view>
  </view>

  <view class="stat-row card">
    <view class="stat-item" data-tab="posts" bindtap="onStatTap">
      <view class="stat-num">{{formatCount(profile.stats.postCount)}}</view>
      <view class="stat-label">帖子</view>
    </view>
    <view class="stat-item" data-tab="followers" bindtap="onStatTap">
      <view class="stat-num">{{formatCount(profile.stats.followerCount)}}</view>
      <view class="stat-label">粉丝</view>
    </view>
    <view class="stat-item" data-tab="following" bindtap="onStatTap">
      <view class="stat-num">{{formatCount(profile.stats.followingCount)}}</view>
      <view class="stat-label">关注</view>
    </view>
    <view class="stat-item">
      <view class="stat-num">{{formatCount(profile.stats.likeReceivedCount)}}</view>
      <view class="stat-label">获赞</view>
    </view>
    <view class="stat-item" data-tab="favorites" bindtap="onStatTap">
      <view class="stat-num">{{formatCount(profile.stats.favoriteCount)}}</view>
      <view class="stat-label">收藏</view>
    </view>
  </view>

  <view class="content-section card">
    <view class="content-tabs tabs">
      <view
        wx:for="{{contentTabs}}"
        wx:key="key"
        class="content-tab {{activeTab === item.key ? 'is-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onTabChange"
      >{{item.label}}</view>
    </view>

    <view wx:if="{{activeTab === 'posts'}}" class="tab-content">
      <block wx:for="{{myPosts}}" wx:key="postId">
        <view class="post-card" data-id="{{item.postId}}" bindtap="onPostTap">
          <view class="post-card-header">
            <view class="post-card-title">
              <text wx:if="{{item.isAnonymous}}">[匿名] </text>{{item.title}}
            </view>
            <text class="post-card-time">{{item.createdAtText || item.createdAt}}</text>
          </view>
          <view class="post-card-meta">
            <text>{{item.topicName}} · {{item.contentTypeLabel}}</text>
            <text wx:if="{{item.isBest}}" class="best-badge">精选</text>
          </view>
          <view class="post-card-stats">
            <text>赞 {{item.likeCount}}</text>
            <text>评 {{item.commentCount}}</text>
            <text>阅 {{item.viewCount}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{!myPosts.length}}" class="empty-state">你还没有发布过帖子，去社区发一条吧</view>
    </view>

    <view wx:if="{{activeTab === 'favorites'}}" class="tab-content">
      <block wx:for="{{myFavorites}}" wx:key="postId">
        <view class="fav-card" data-id="{{item.postId}}" bindtap="onPostTap">
          <view class="fav-title">{{item.title}}</view>
          <view class="fav-meta">{{item.author.nickname}} · {{item.topicName}}</view>
          <view class="fav-stats">
            <text>赞 {{item.likeCount}}</text>
            <text>评 {{item.commentCount}}</text>
            <text>{{item.savedAt}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{!myFavorites.length}}" class="empty-state">暂无收藏内容</view>
    </view>

    <view wx:if="{{activeTab === 'history'}}" class="tab-content">
      <view class="history-clear" bindtap="clearHistory">清空历史</view>
      <block wx:for="{{myHistory}}" wx:key="postId">
        <view class="history-card" data-id="{{item.postId}}" bindtap="onPostTap">
          <view class="history-title">{{item.title}}</view>
          <view class="history-meta">
            <text>{{item.topicName}}</text>
            <text class="history-time">{{item.viewedAt}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{!myHistory.length}}" class="empty-state">暂无浏览历史</view>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-row" bindtap="goFollowList" data-type="following">
      <text class="menu-text">关注 / 粉丝</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row" bindtap="handleMenuTap" data-name="我的草稿">
      <text class="menu-text">我的草稿</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row" bindtap="goSettings">
      <text class="menu-text">消息与设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row" bindtap="handleMenuTap" data-name="意见反馈">
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row" bindtap="handleMenuTap" data-name="关于我们">
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-btn btn btn-secondary-muted" bindtap="handleLogout">退出登录</view>
</view>
