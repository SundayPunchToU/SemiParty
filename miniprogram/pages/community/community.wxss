.community-shell {
  position: relative;
}

.page-title {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.category-row {
  display: flex;
  gap: 0;
  justify-content: space-between;
  margin: 6rpx 0 12rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.category-chip {
  flex: 1;
  padding: 12rpx 24rpx;
  border-radius: 0;
  border: none;
  border-bottom: 4rpx solid transparent;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.category-chip.is-active {
  background: none;
  color: var(--color-primary);
  font-weight: 600;
  border-bottom-color: var(--color-primary);
}

.topic-scroll {
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.topic-row {
  display: flex;
  gap: 12rpx;
}

.topic-pill {
  opacity: 0.86;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
}

.topic-pill.is-active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.16);
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 140rpx);
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 18rpx 36rpx rgba(14, 66, 145, 0.35);
}
