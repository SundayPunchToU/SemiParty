<view class="page-shell community-shell">
  <view class="top-safe" style="padding-top: {{statusBarHeight + 8}}px; padding-right: {{navCapsuleInsetRight}}px;">
    <view class="community-topbar" style="min-height: {{capsuleHeight}}px;">
      <view>
        <view class="community-title">社区</view>
        <view class="community-subtitle">唯一茶水间</view>
      </view>
      <view class="community-action" bindtap="handleCreatePost">发帖</view>
    </view>
  </view>

  <view class="community-search" bindtap="onSearchTap">
    <text class="community-search-icon">⌕</text>
    <text class="community-search-text">搜索帖子、话题、岗位、资讯</text>
  </view>

  <view class="tea-room-summary">
    <view class="tea-room-summary-title">晶圆茶水间</view>
    <view class="tea-room-summary-text">{{onlineCount}} 人在线 · 今日 {{todayPostCount}} 帖</view>
  </view>

  <scroll-view class="topic-scroll" scroll-x="true" enable-flex="true" show-scrollbar="{{false}}">
    <view class="topic-row">
      <view
        wx:for="{{topics}}"
        wx:key="topicId"
        class="topic-chip {{activeTopicId === item.topicId ? 'is-active' : ''}}"
        data-topicid="{{item.topicId}}"
        bindtap="onTopicTap"
      >
        {{item.topicName}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading && !posts.length}}" class="community-placeholder">加载中...</view>
  <view wx:elif="{{!posts.length}}" class="community-placeholder">还没有帖子，去发第一条吧</view>

  <view wx:else class="community-feed">
    <post-card
      wx:for="{{posts}}"
      wx:key="id"
      item="{{item}}"
      bind:cardtap="openPostDetail"
      bind:comment="openComment"
      bind:like="handleLike"
      bind:share="handleShare"
    />
    <view class="community-footer">{{hasMore ? (loadingMore ? '加载中...' : '') : '没有更多帖子了'}}</view>
  </view>
</view>
