.publish-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 96rpx;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  padding-bottom: env(safe-area-inset-bottom);
}

.create-nav {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
}

.inner-title {
  justify-self: center;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}

.nav-link {
  justify-self: start;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.nav-action {
  justify-self: end;
}

.publish-btn {
  width: 108rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.editor {
  width: 100%;
  min-height: 320rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: var(--color-bg-elevated);
  color: var(--color-text-primary);
  font-size: 32rpx;
  line-height: 1.6;
}

.editor-placeholder {
  color: var(--color-text-tertiary);
}

.editor-section {
  margin-top: 28rpx;
}

.editor-label {
  font-size: 28rpx;
  font-weight: 700;
}

.editor-tip {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.topic-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.topic-choice {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.topic-choice.is-active {
  background: rgba(42, 127, 255, 0.14);
  color: #96c7ff;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.image-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.image-cell,
.image-add {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
  background: var(--color-bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
  font-size: 42rpx;
}
