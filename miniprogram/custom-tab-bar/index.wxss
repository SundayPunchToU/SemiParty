/* === STEP 1.1 新增：自定义 TabBar 样式 === */
/* === STEP 2.4 增强：中央凸起按钮 + 发帖入口面板 === */
.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50px;
  background: #2B2A27;
  border-top: 1rpx solid #3A3937;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 4px;
}

.tab-bar-item-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 0;
}

/* 中央凸起按钮 */
.center-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, #2A7FFF, #5B9BFF);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -12px;
  box-shadow: 0 4px 12px rgba(42, 127, 255, 0.5);
}

.center-btn-icon {
  color: #ffffff;
  font-size: 24px;
  font-weight: 300;
  line-height: 1;
}

.tab-icon-wrap {
  position: relative;
  width: 24px;
  height: 24px;
}

.tab-icon {
  width: 24px;
  height: 24px;
}

.tab-text {
  font-size: 10px;
  margin-top: 2px;
}

/* === STEP 1.1 修改开始：消息 Tab 未读角标样式 === */
.badge {
  position: absolute;
  top: -6px;
  right: -10px;
  min-width: 18px;
  height: 18px;
  line-height: 18px;
  text-align: center;
  background: #FF3B30;
  color: #FFFFFF;
  font-size: 10px;
  border-radius: 9px;
  padding: 0 4px;
  box-sizing: border-box;
}
/* === STEP 1.1 修改结束 === */

/* === STEP 1.1 修改开始：社区 Tab 小红点样式 === */
.red-dot {
  position: absolute;
  top: -2px;
  right: -2px;
  width: 8px;
  height: 8px;
  background: #FF3B30;
  border-radius: 50%;
}
/* === STEP 1.1 修改结束 === */

/* ── 发帖入口面板 ── */
.post-panel-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.post-panel {
  width: 100%;
  background: #1E1E32;
  border-radius: 40rpx 40rpx 0 0;
  padding: 48rpx 36rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.post-panel-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: space-between;
  width: 100%;
}

.post-card {
  width: calc(50% - 12rpx);
  height: 176rpx;
  background: #2A2A3E;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.post-card:active {
  background: #3A3A4E;
}

.post-card-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.post-card-info {
  display: flex;
  flex-direction: column;
}

.post-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.post-card-subtitle {
  font-size: 24rpx;
  color: #888888;
}

.post-panel-close {
  margin-top: 40rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #2A2A3E;
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-panel-close-icon {
  color: #ffffff;
  font-size: 32rpx;
}
