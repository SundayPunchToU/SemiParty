<view class="page-shell">
  <!-- ① 顶部导航栏 -->
  <view class="top-safe" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar" style="height: {{capsuleHeight}}px;">
      <view class="nav-back" bindtap="goBack">
        <text>←</text>
      </view>
      <view class="nav-title">申请创建专区</view>
      <view class="nav-submit {{formValid ? '' : 'disabled'}}" bindtap="onSubmit">提交</view>
    </view>
  </view>

  <!-- ② 表单区域 -->
  <view class="form-area">
    <!-- 专区名称 -->
    <view class="form-group">
      <view class="form-label">专区名称 <text class="required">*</text></view>
      <input class="form-input" placeholder="如：SiC外延技术、合肥半导体人" maxlength="20" value="{{form.name}}" bindinput="onNameInput" />
    </view>

    <!-- 专区分类 -->
    <view class="form-group">
      <view class="form-label">专区分类 <text class="required">*</text></view>
      <view class="chip-group">
        <view wx:for="{{categories}}" wx:key="key"
          class="chip {{form.category === item.key ? 'is-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onCategoryTap"
        >{{item.name}}</view>
      </view>
    </view>

    <!-- 专区简介 -->
    <view class="form-group">
      <view class="form-label">专区简介 <text class="required">*</text></view>
      <textarea class="form-textarea" placeholder="简单描述这个专区讨论什么话题…" maxlength="200" value="{{form.desc}}" bindinput="onDescInput" style="min-height: 200rpx;" />
    </view>

    <!-- 专区图标 -->
    <view class="form-group">
      <view class="form-label">专区图标（选填）</view>
      <view class="icon-upload" bindtap="onUploadIcon">
        <text class="icon-upload-plus">+</text>
      </view>
    </view>

    <!-- 建议内容类型 -->
    <view class="form-group">
      <view class="form-label">建议内容类型（选填，多选）</view>
      <view class="chip-group">
        <view wx:for="{{contentTypes}}" wx:key="key"
          class="chip {{form.contentTypes.indexOf(item.key) >= 0 ? 'is-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onContentTypeTap"
        >{{item.name}}</view>
      </view>
    </view>

    <!-- 申请理由 -->
    <view class="form-group">
      <view class="form-label">申请理由（选填）</view>
      <textarea class="form-textarea" placeholder="为什么需要这个专区…" maxlength="500" value="{{form.reason}}" bindinput="onReasonInput" style="min-height: 160rpx;" />
    </view>

    <!-- 底部提示 -->
    <view class="form-hint">提交后将由管理员审核，通常 1-3 个工作日内反馈</view>
  </view>

  <!-- ③ 成功弹窗 -->
  <view wx:if="{{showSuccess}}" class="success-overlay" bindtap="onSuccessClose">
    <view class="success-modal" catchtap="">
      <text class="success-icon">✅</text>
      <text class="success-title">申请已提交</text>
      <text class="success-desc">审核通过后将通知你</text>
      <view class="success-btn" bindtap="onSuccessClose">知道了</view>
    </view>
  </view>
</view>
