.page-profile {
  min-height: 100vh;
  background: #1A1A2E;
}

/* 顶部导航 */
.top-nav {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #1A1A2E;
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.brand {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
}
.nav-right {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* ① 个人信息卡片 */
.profile-card {
  position: relative;
  margin: 0 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
}
.card-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 200rpx;
  background: linear-gradient(180deg, rgba(42,127,255,0.3) 0%, transparent 100%);
}
.card-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx 28rpx;
}
.avatar-wrap {
  margin-bottom: 16rpx;
}
.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2A7FFF, #5B9CFF);
  color: #fff;
  font-size: 52rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.2);
}
.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}
.profile-role {
  font-size: 26rpx;
  color: #aaa;
  margin-top: 8rpx;
}
.profile-bio {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
  text-align: center;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  max-width: 80%;
}
.badge-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}
.badge-chip {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 16rpx;
  background: #2A2A3E;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #ccc;
}
.edit-btn {
  margin-top: 20rpx;
  padding: 12rpx 48rpx;
  border: 2rpx solid #2A7FFF;
  border-radius: 24rpx;
  color: #2A7FFF;
  font-size: 26rpx;
  font-weight: 600;
}

/* ② 数据统计 */
.stat-row {
  display: flex;
  padding: 28rpx 24rpx;
  margin-top: 8rpx;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
}
.stat-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}

/* ③ 专区横滚 */
.section-block {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}
.section-link {
  font-size: 24rpx;
  color: #888;
}
.zone-scroll {
  white-space: nowrap;
}
.zone-chips {
  display: flex;
  gap: 16rpx;
}
.zone-chip {
  display: inline-flex;
  padding: 12rpx 24rpx;
  background: #2A2A3E;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* ④ 内容Tab */
.content-section {
  margin: 0 24rpx;
}
.content-tabs {
  display: flex;
  border-bottom: 1rpx solid #333;
}
.content-tab {
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: #888;
  position: relative;
}
.content-tab.is-active {
  color: #fff;
  font-weight: 600;
}
.content-tab.is-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #2A7FFF;
  border-radius: 2rpx;
}
.tab-content {
  padding-top: 8rpx;
}

/* 我的帖子 */
.post-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #222;
}
.post-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}
.post-card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.post-card-time {
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}
.post-card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}
.best-badge {
  color: #FFD700;
}
.post-card-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
}

/* 我的收藏 */
.fav-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #222;
}
.fav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.fav-meta {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}
.fav-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
}

/* 浏览历史 */
.history-clear {
  text-align: right;
  font-size: 24rpx;
  color: #888;
  padding: 8rpx 0 12rpx;
}
.history-card {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #222;
}
.history-title {
  font-size: 28rpx;
  color: #ddd;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.history-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666;
}
.history-time {
  flex-shrink: 0;
}

.empty-state {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #777;
}


/* ⑤ 功能入口 */
.menu-section {
  padding: 24rpx 24rpx 0;
}
.menu-card {
  background: #2A2A3E;
  border-radius: 24rpx;
  overflow: hidden;
}
.menu-row {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  height: 100rpx;
  border-bottom: 1rpx solid #333;
}
.menu-row:last-child {
  border-bottom: none;
}
.menu-emoji {
  font-size: 32rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #eee;
}
.menu-arrow {
  font-size: 28rpx;
  color: #555;
}
.logout-card {
  margin-top: 24rpx;
  padding: 28rpx;
  text-align: center;
  background: #2A2A3E;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #FF4D4F;
  font-weight: 600;
}
