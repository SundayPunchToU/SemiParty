/* pages/tea-room/tea-room.wxss */

.tea-room-page {
  min-height: 100vh;
  background: #1E1E32;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ── ① 顶部导航栏 ── */
.tea-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #1E1E32;
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 700;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.nav-action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-action-icon {
  font-size: 30rpx;
}

/* ── ② 氛围头部卡片 ── */
.tea-header {
  width: 100%;
  background: linear-gradient(180deg, #2E2418, #1E1E32);
  transition: height 0.05s linear, opacity 0.15s ease;
}

.header-content {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
  box-sizing: border-box;
}

.header-main {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.header-emoji {
  font-size: 64rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.header-text {
  flex: 1;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #AAAAAA;
}

.header-stats {
  font-size: 24rpx;
  color: #888888;
}

/* ── ③ 话题标签横滑栏 ── */
.topic-bar {
  background: #1E1E32;
}

.topic-scroll {
  white-space: nowrap;
}

.topic-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.topic-chip {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  background: #2A2A3E;
  color: #AAAAAA;
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.topic-chip.is-active {
  background: #2A7FFF;
  color: #ffffff;
}

/* ── ④ 帖子流 ── */
.post-list {
  padding: 0 24rpx;
}

.post-item {
  margin-bottom: 0;
}

/* ── 空态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: #8D6E63;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 32rpx;
}

/* ── 加载更多 / 没有更多 ── */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: #888888;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.no-more-text {
  font-size: 24rpx;
  color: #555555;
}

/* ── ⑤ 浮动发帖按钮 ── */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #8D6E63;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 24rpx rgba(141, 110, 99, 0.4);
  z-index: 200;
}
