.page-create {
  min-height: 100vh;
  background: #0b0d12;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e9ebf0;
  font-size: 32rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #e9ebf0;
  font-size: 32rpx;
  font-weight: 600;
}

.nav-submit {
  min-width: 120rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #3b82f6;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.nav-submit.is-disabled {
  background: #252a38;
  color: #666666;
}

.topic-row-wrapper {
  margin-top: 24rpx;
}

.topic-row-label {
  margin-bottom: 16rpx;
  color: #8a90a0;
  font-size: 24rpx;
}

.topic-row {
  white-space: nowrap;
}

.topic-row-inner {
  display: flex;
  gap: 16rpx;
  padding-right: 24rpx;
}

.topic-chip {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #151821;
  color: #8a90a0;
  font-size: 24rpx;
}

.topic-chip.is-active {
  background: #3b82f6;
  color: #ffffff;
}

.editor {
  width: 100%;
  min-height: 420rpx;
  margin-top: 32rpx;
  color: #e9ebf0;
  font-size: 30rpx;
  line-height: 1.65;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx;
  background: #0b0d12;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.anon-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.anon-label {
  color: #8a90a0;
  font-size: 24rpx;
}
