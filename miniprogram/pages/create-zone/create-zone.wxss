.page-shell {
  min-height: 100vh;
  background: #1A1A2E;
}

.top-safe {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #1A1A2E;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 700;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.nav-submit {
  padding: 12rpx 32rpx;
  background: #2A7FFF;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 32rpx;
}

.nav-submit.disabled {
  background: #555555;
  color: #999999;
}

.form-area {
  padding: 0 32rpx;
  padding-top: 180rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #AAAAAA;
  margin-bottom: 12rpx;
}

.required {
  color: #FF4D4F;
}

.form-input {
  background: #2A2A3E;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.form-textarea {
  background: #2A2A3E;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #ffffff;
  width: 100%;
  box-sizing: border-box;
}

.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  background: #2A2A3E;
  color: #AAAAAA;
  font-size: 26rpx;
}

.chip.is-active {
  background: #2A7FFF;
  color: #ffffff;
}

.icon-upload {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  background: #2A2A3E;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-upload-plus {
  font-size: 48rpx;
  color: #888888;
}

.form-hint {
  text-align: center;
  font-size: 24rpx;
  color: #666666;
  padding: 40rpx 0;
}

/* 成功弹窗 */
.success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.success-modal {
  width: 560rpx;
  background: #2A2A3E;
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #AAAAAA;
  margin-bottom: 48rpx;
}

.success-btn {
  width: 100%;
  padding: 24rpx;
  background: #2A7FFF;
  color: #ffffff;
  font-size: 30rpx;
  text-align: center;
  border-radius: 16rpx;
}
