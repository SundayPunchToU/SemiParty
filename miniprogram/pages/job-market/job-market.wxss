.inner-top {
  margin-bottom: 22rpx;
}

.inner-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.inner-title-box {
  flex: 1;
}

.inner-title {
  font-size: 42rpx;
  font-weight: 700;
}

.inner-subtitle {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.segment {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: var(--color-bg-muted);
}

.segment-item {
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
  font-size: 30rpx;
  font-weight: 700;
}

.segment-item.is-active {
  background: #fff;
  color: var(--color-primary-strong);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.12);
}

.filter-scroll {
  margin: 18rpx 0 22rpx;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 12rpx;
}

.filter-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.filter-chip.is-active {
  border-color: rgba(42, 127, 255, 0.4);
  background: rgba(42, 127, 255, 0.12);
  color: #9bc9ff;
}

.market-list {
  margin-top: 22rpx;
}
