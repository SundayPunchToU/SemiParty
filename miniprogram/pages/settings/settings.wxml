<view class="page-settings page-detail-shell">
  <view class="top-nav" style="padding-top: {{statusBarHeight + 8}}px; padding-right: {{navCapsuleInsetRight}}px;">
    <view class="nav-inner" style="min-height: {{capsuleHeight}}px;">
      <view class="back-btn" bindtap="goBack">‹</view>
      <view class="nav-title">设置</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <view class="settings-group card">
    <view class="settings-row" bindtap="goPrivacy">
      <text class="row-text">账号与安全</text>
      <text class="row-arrow">›</text>
    </view>
    <view class="settings-row" bindtap="goPrivacy">
      <text class="row-text">隐私设置</text>
      <text class="row-arrow">›</text>
    </view>
    <view class="settings-row" bindtap="goNotification">
      <text class="row-text">通知设置</text>
      <text class="row-arrow">›</text>
    </view>
    <view class="settings-row">
      <text class="row-text">深色模式</text>
      <switch checked="{{darkMode}}" color="#3b82f6" bindchange="onDarkModeChange" />
    </view>
    <view class="settings-row" bindtap="handleFontSize">
      <text class="row-text">字体大小</text>
      <view class="row-right">
        <text class="row-value">标准</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="settings-group card">
    <view class="settings-row" bindtap="handleClearCache">
      <text class="row-text">清除缓存</text>
      <view class="row-right">
        <text class="row-value">128.5 MB</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
    <view class="settings-row" bindtap="handleFeedback">
      <text class="row-text">意见反馈</text>
      <text class="row-arrow">›</text>
    </view>
    <view class="settings-row" bindtap="handleAbout">
      <text class="row-text">关于 SemiParty</text>
      <text class="row-arrow">›</text>
    </view>
    <view class="settings-row" bindtap="handleCheckUpdate">
      <text class="row-text">检查更新</text>
      <view class="row-right">
        <text class="row-value">v2.0.0</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="logout-btn btn btn-secondary-muted" bindtap="handleLogout">退出登录</view>
</view>
