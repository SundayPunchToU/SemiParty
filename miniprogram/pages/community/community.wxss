.community-shell {
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.community-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.community-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.community-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.community-action {
  min-width: 112rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: var(--color-primary-text);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.community-search {
  height: 84rpx;
  padding: 0 24rpx;
  margin: 24rpx 0 18rpx;
  border-radius: 24rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.community-search-icon {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.community-search-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.tea-room-summary {
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.tea-room-summary-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.tea-room-summary-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.topic-scroll {
  margin: 24rpx 0 20rpx;
  white-space: nowrap;
}

.topic-row {
  display: flex;
  gap: 14rpx;
}

.topic-chip {
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  color: var(--color-text-secondary);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.topic-chip.is-active {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.community-placeholder,
.community-footer {
  padding: 36rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.community-feed {
  padding-bottom: 40rpx;
}
